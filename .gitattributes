# Set default behavior to automatically handle line endings
* text=auto

# Declare files that must always be LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.txt text eol=lf
*.dtd text eol=lf
*.c text eol=lf
*.h text eol=lf
*.nsi text eol=lf
*.nsh text eol=lf
*.sgp text eol=lf
*.ini text eol=lf
*.MF text eol=lf
*.sh text eol=lf
.gitignore text eol=lf
pom.xml text eol=lf
build.xml text eol=lf

# Declare files that must always be CRLF
*.bat text eol=crlf
